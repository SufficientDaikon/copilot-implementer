{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "./scripts/detect-spec.sh",
        "windows": "powershell -ExecutionPolicy Bypass -File scripts\\detect-spec.ps1",
        "timeout": 10
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "./scripts/on-impl-complete.sh",
        "windows": "powershell -ExecutionPolicy Bypass -File scripts\\on-impl-complete.ps1",
        "timeout": 10
      }
    ]
  }
}
